# Path B harness configuration. Copy to config.env and `source` it.
# Run this only inside a throwaway macOS VM — see docs/throwaway-macos-vm.md.

# --- Judge model (OpenAI-compatible Chat Completions endpoint) ---
# Used by the harness PARENT process only; it is scrubbed from the agent's env.
export GENSEE_JUDGE_BASE_URL="https://api.openai.com/v1"
export GENSEE_JUDGE_API_KEY="sk-..."
export GENSEE_JUDGE_MODEL="gpt-4o"

# --- Target agent (Claude Code) ---
# Value passed to `claude --model`. Leave unset to use the Claude Code default.
export GENSEE_TARGET_MODEL="claude-sonnet-4"

# Because HOME is faked and the env is scrubbed, the agent authenticates via this
# key (forwarded to the child). Use a throwaway key inside the VM.
export ANTHROPIC_API_KEY="sk-ant-..."

# Acknowledge that the benchmark runs real destructive payloads on this machine.
# Equivalent to passing --i-understand-the-risk. Only set this inside the VM.
# export GENSEE_EVAL_ACK_RISK=1
